{
  "name": "kalkulator-depresiasi-aset-perusahaan",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Kalkulator Depresiasi Aset Perusahaan berbasis Excel, PWA, APK Android, export file, PDF report, dan dark mode.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "assets:android": "capacitor-assets generate --android",
    "apk:debug": "npm run build && npm run cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.3",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  }
}
